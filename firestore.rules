rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the requester owns the target document ID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // User logged carbon activities
    match /activities/{activityId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Carbon reduction goals
    match /goals/{goalId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Personalised insights & SmartAdvisor recommendations
    match /insights/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Seeded educational articles (publicly readable if published, writes disabled)
    match /education/{slug} {
      allow read: if resource.data.published == true;
      allow write: if false;
    }
  }
}
